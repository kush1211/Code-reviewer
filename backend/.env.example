# Database
DATABASE_URL=postgresql+asyncpg://reviewly:reviewly@localhost:5432/reviewly

# Redis
REDIS_URL=redis://localhost:6379/0

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_random_hex_string
JWT_EXPIRY_SECONDS=3600

# Fernet encryption key — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_me_to_a_fernet_key

# Anthropic (required when LLM_MODEL starts with "anthropic:")
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (required when LLM_MODEL starts with "openai:")
# OPENAI_API_KEY=sk-...

# LLM model — format: "<provider>:<model>"
# Examples:
#   anthropic:claude-sonnet-4-5   (default)
#   anthropic:claude-opus-4-5
#   openai:gpt-4o
#   openai:gpt-4o-mini
LLM_MODEL=anthropic:claude-sonnet-4-5

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Webhook base URL (publicly reachable — use ngrok in dev)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io
